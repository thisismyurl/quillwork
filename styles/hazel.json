{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Hazel",
  "settings": {
    "custom": {
      "colophon-light": "#f5f0e4",
      "colophon-dark": "#1a1512",
      "colophon-accent": "#6a580f"
    },
    "color": {
      "palette": [
        {
          "slug": "ink-deep",
          "color": "#1a1512",
          "name": "Ink Deep"
        },
        {
          "slug": "ink-medium",
          "color": "#2e261e",
          "name": "Ink Medium"
        },
        {
          "slug": "ink-muted",
          "color": "#6e5e50",
          "name": "Ink Muted"
        },
        {
          "slug": "teal",
          "color": "#6a580f",
          "name": "Teal"
        },
        {
          "slug": "teal-light",
          "color": "#b09630",
          "name": "Teal Light"
        },
        {
          "slug": "teal-tint",
          "color": "#ede4c4",
          "name": "Teal Tint"
        },
        {
          "slug": "ochre",
          "color": "#c4a040",
          "name": "Ochre"
        },
        {
          "slug": "cream",
          "color": "#f5f0e4",
          "name": "Cream"
        },
        {
          "slug": "paper-white",
          "color": "#fdf8f0",
          "name": "Paper White"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--cream)",
      "text": "var(--wp--preset--color--ink-deep)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--teal)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink-deep)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--ink-deep)",
          "text": "var(--wp--preset--color--cream)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-medium)"
        }
      }
    }
  }
}