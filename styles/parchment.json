{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Parchment",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink-deep",
          "color": "#1C0C04",
          "name": "Ink Deep"
        },
        {
          "slug": "ink-medium",
          "color": "#38200C",
          "name": "Ink Medium"
        },
        {
          "slug": "ink-muted",
          "color": "#6E5838",
          "name": "Ink Muted"
        },
        {
          "slug": "teal",
          "color": "#1A5A60",
          "name": "Teal"
        },
        {
          "slug": "teal-light",
          "color": "#2A7880",
          "name": "Teal Light"
        },
        {
          "slug": "teal-tint",
          "color": "#D8EAE8",
          "name": "Teal Tint"
        },
        {
          "slug": "ochre",
          "color": "#C8904A",
          "name": "Ochre"
        },
        {
          "slug": "ochre-warm",
          "color": "#A87040",
          "name": "Ochre Warm"
        },
        {
          "slug": "coral",
          "color": "#C07060",
          "name": "Coral"
        },
        {
          "slug": "cream",
          "color": "#EDE0BE",
          "name": "Cream"
        },
        {
          "slug": "paper-white",
          "color": "#F8F0D8",
          "name": "Paper White"
        }
      ]
    },
    "custom": {
      "colophon-light": "#EDE0BE",
      "colophon-dark": "#1C0C04",
      "colophon-accent": "#1A5A60"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--cream)",
      "text": "var(--wp--preset--color--ink-deep)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--teal)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink-deep)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--teal)",
          "text": "var(--wp--preset--color--paper-white)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-medium)"
        }
      }
    }
  }
}
