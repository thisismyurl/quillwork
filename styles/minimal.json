{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Minimal",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink-deep",
          "color": "#111111",
          "name": "Ink Deep"
        },
        {
          "slug": "ink-medium",
          "color": "#333333",
          "name": "Ink Medium"
        },
        {
          "slug": "ink-muted",
          "color": "#666666",
          "name": "Ink Muted"
        },
        {
          "slug": "teal",
          "color": "#444444",
          "name": "Teal"
        },
        {
          "slug": "teal-light",
          "color": "#666666",
          "name": "Teal Light"
        },
        {
          "slug": "teal-tint",
          "color": "#F0F0F0",
          "name": "Teal Tint"
        },
        {
          "slug": "ochre",
          "color": "#888880",
          "name": "Ochre"
        },
        {
          "slug": "ochre-warm",
          "color": "#777770",
          "name": "Ochre Warm"
        },
        {
          "slug": "coral",
          "color": "#888070",
          "name": "Coral"
        },
        {
          "slug": "cream",
          "color": "#FFFFFF",
          "name": "Cream"
        },
        {
          "slug": "paper-white",
          "color": "#FFFFFF",
          "name": "Paper White"
        }
      ]
    },
    "custom": {
      "colophon-light": "#FFFFFF",
      "colophon-dark": "#111111",
      "colophon-accent": "#444444"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--cream)",
      "text": "var(--wp--preset--color--ink-deep)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--teal)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink-deep)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--ink-deep)",
          "text": "var(--wp--preset--color--cream)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-medium)"
        }
      }
    }
  }
}
